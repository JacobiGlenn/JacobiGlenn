name: Guestbook

on:
  schedule:
    - cron: '*/5 * * * *'  # Runs every 5 minutes
  issues:
    types: [opened, edited, deleted, labeled, unlabeled]
  issue_comment:
    types: [created, edited, deleted]
  workflow_dispatch:

permissions:
  contents: write
  issues: read
  pull-requests: write

jobs:
  update-guestbook:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Update Guestbook
        uses: marketplace/guestbook-action@v1
        with:
          gh_token: ${{ secrets.GITHUB_TOKEN }}
          issue_label: 'Guestbook Entry'
          max_entries: 2
          readme_path: './README.md'
          section_start: '<!-- START_SECTION:guestbook -->'
          section_end: '<!-- END_SECTION:guestbook -->'
